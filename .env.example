# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Portales — MercadoLibre (OAuth)
ML_APP_ID=
ML_SECRET_KEY=

# Portales — Argenprop (API REST integradores.api.sosiva451.com v1)
# Auth doble: header X-Token-CRM (token fijo del integrador) + Authorization: Bearer
# (token de usuario que se obtiene con POST /v1/auth/login usando ARGENPROP_USR/PSD).
# El usuario/clave y el Token CRM salen del portal developers.argenprop.com.
# ARGENPROP_ID_ANUNCIANTE = Id de la inmobiliaria (GET /v1/inmobiliarias/{id}).
ARGENPROP_API_BASE=https://integradores.api.sosiva451.com
ARGENPROP_TOKEN_CRM=
ARGENPROP_USR=
ARGENPROP_PSD=
ARGENPROP_ID_ANUNCIANTE=

# Portales — ZonaProp (sync API)
ZONAPROP_API_KEY=
ZONAPROP_CLIENT_CODE=
ZONAPROP_API_BASE=https://api.zonaprop.com.ar/v2

# Geocoding (para backfill de lat/lng en propiedades existentes)
GOOGLE_GEOCODING_API_KEY=

# AI providers (generador de descripciones GPT Portales + copy AI de Meta)
# El sistema usa DeepSeek por default por costo (~10x más barato que OpenAI
# para calidad comparable en tareas de copy en español). API 100% compatible
# OpenAI — solo cambia URL base y modelo.
#
# Configurá UNA de las dos opciones:
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# Opcional: forzar provider explícito ('deepseek' | 'openai').
# Si no se setea, auto-detecta según qué API key haya disponible.
AI_PROVIDER=
# Opcional: override del modelo. Defaults:
#   deepseek → deepseek-chat
#   openai   → gpt-4o-mini
AI_MODEL=

# Meta Ads — campaign builder (Fase 2 M14)
# META_AD_ACCOUNT_ID y META_ACCESS_TOKEN ya están en sección Meta Ads de arriba.
# Adicional necesario:
META_PAGE_ID=
# Pixel ID para tracking en landing (PageView, ViewContent, Lead).
# Opcional pero recomendado: sin pixel, Meta no puede optimizar leads.
META_PIXEL_ID=
# USD_TO_ARS: opcional. Si no se setea, el sistema obtiene la tasa
# automáticamente desde Bluelytics (dólar blue). Solo setearlo para
# tests o si querés forzar una tasa fija.
USD_TO_ARS=

# ── Consultas de portales → WhatsApp (Gmail polling) ─────────────────────────
# El cron /api/cron/portal-inquiries escanea la casilla de Gmail donde llegan
# las consultas de MercadoLibre / ZonaProp / Argenprop, parsea el lead + la
# propiedad, identifica al asesor (vía portal_property_map) y avisa por WhatsApp.

# Gmail — método A (RECOMENDADO): OAuth con refresh token. NO requiere key de
# cuenta de servicio → esquiva la org policy iam.disableServiceAccountKeyCreation.
# Obtené el refresh token (login una vez):  npx tsx scripts/gmail-oauth-setup.ts
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
# Casilla a leer (la que recibe los emails de los portales).
GMAIL_IMPERSONATE_EMAIL=contacto@diegoferreyrainmobiliaria.com

# Gmail — método B (alternativo): cuenta de servicio + domain-wide delegation.
# Solo si la organización permite crear keys de service account (Admin Console →
# Seguridad → Controles de API → Delegación, scope gmail.readonly).
GMAIL_SA_CLIENT_EMAIL=
# Private key PEM. Los saltos de línea pueden ir escapados como \n.
GMAIL_SA_PRIVATE_KEY=

# WhatsApp Cloud API (Meta) — app/token DISTINTOS de los de Meta Ads.
# El número EMISOR debe estar registrado en Cloud API (no puede ser un número
# ya en uso en la app de WhatsApp normal). Mensajes iniciados por el negocio
# requieren una PLANTILLA pre-aprobada por Meta.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# System-user token con permiso whatsapp_business_messaging (no expira).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_NAME=nueva_consulta_portal
WHATSAPP_TEMPLATE_LANG=es_AR
# Modo prueba: 'true' (default seguro) NO envía, solo loguea. Poner 'false'
# para activar el envío real (recién después de validar parseo + match).
WHATSAPP_TEST_MODE=true
# Fallback del teléfono de Diego (dueño) si profiles.phone está vacío. E.164.
WHATSAPP_FALLBACK_PHONE=

