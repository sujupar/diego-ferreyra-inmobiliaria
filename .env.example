# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Portales — MercadoLibre (OAuth)
ML_APP_ID=
ML_SECRET_KEY=

# Portales — Argenprop (REST + API key)
ARGENPROP_API_KEY=
ARGENPROP_CLIENT_CODE=
ARGENPROP_API_BASE=https://api.argenprop.com/v1

# Portales — ZonaProp (sync API)
ZONAPROP_API_KEY=
ZONAPROP_CLIENT_CODE=
ZONAPROP_API_BASE=https://api.zonaprop.com.ar/v2

# Geocoding (para backfill de lat/lng en propiedades existentes)
GOOGLE_GEOCODING_API_KEY=

# Meta Ads — campaign builder (Fase 2 M14)
# META_AD_ACCOUNT_ID y META_ACCESS_TOKEN ya están en sección Meta Ads de arriba.
# Adicional necesario:
META_PAGE_ID=
# Conversión USD→ARS para tier de budget (fallback 1200)
USD_TO_ARS=
