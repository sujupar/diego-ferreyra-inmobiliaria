# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Portales — MercadoLibre (OAuth)
ML_APP_ID=
ML_SECRET_KEY=

# Portales — Argenprop (REST + API key)
ARGENPROP_API_KEY=
ARGENPROP_CLIENT_CODE=
ARGENPROP_API_BASE=https://api.argenprop.com/v1

# Portales — ZonaProp (sync API)
ZONAPROP_API_KEY=
ZONAPROP_CLIENT_CODE=
ZONAPROP_API_BASE=https://api.zonaprop.com.ar/v2

# Portales — Properati
PROPERATI_API_KEY=
PROPERATI_CLIENT_CODE=
PROPERATI_API_BASE=https://api.properati.com.ar/v1

# Portales — Mudafy
MUDAFY_API_KEY=
MUDAFY_CLIENT_CODE=
MUDAFY_API_BASE=https://api.mudafy.com/v1

# Geocoding (para backfill de lat/lng en propiedades existentes)
GOOGLE_GEOCODING_API_KEY=

# OpenAI (generador de descripciones para portales — GPT Portales)
OPENAI_API_KEY=
# Opcional. Default gpt-4o-mini (rápido y barato). Subir a gpt-4o si se
# requiere mejor calidad.
OPENAI_MODEL=

# Meta Ads — campaign builder (Fase 2 M14)
# META_AD_ACCOUNT_ID y META_ACCESS_TOKEN ya están en sección Meta Ads de arriba.
# Adicional necesario:
META_PAGE_ID=
# Pixel ID para tracking en landing (PageView, ViewContent, Lead).
# Opcional pero recomendado: sin pixel, Meta no puede optimizar leads.
META_PIXEL_ID=
# USD_TO_ARS: opcional. Si no se setea, el sistema obtiene la tasa
# automáticamente desde Bluelytics (dólar blue). Solo setearlo para
# tests o si querés forzar una tasa fija.
USD_TO_ARS=

# WhatsApp Business Cloud API (Meta) — notificaciones de lead al asesor
# Setup en Meta Business Manager → WhatsApp → API Setup.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Template aprobado por Meta. Debe tener 4 variables en el body:
# {{1}} nombre asesor, {{2}} nombre lead, {{3}} contacto lead, {{4}} dirección
WHATSAPP_LEAD_TEMPLATE=
# Código de idioma del template. Default es_AR
WHATSAPP_LEAD_TEMPLATE_LANG=es_AR
